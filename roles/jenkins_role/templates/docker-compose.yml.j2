# Template Jinja2 — variables injectées par Ansible au déploiement
# Image : jenkins/jenkins:lts (officielle)
# Remplacement de sadofrazer/jenkins — CentOS 7 EOL + incompatibilité cgroups v2
version: '3.8'
services:
  jenkins:
    image: {{ jenkins_image }}
    container_name: jenkins
    restart: always
    user: root
    ports:
      # Interface web Jenkins
      - "{{ jenkins_port }}:8080"
      # Communication agents Jenkins (JNLP)
      - "{{ jenkins_agent_port }}:50000"
    volumes:
      # Persistance des données Jenkins (jobs, config, plugins)
      - jenkins_home:/var/jenkins_home
      # Accès au socket Docker hôte — permet à Jenkins de lancer des builds Docker
      - /var/run/docker.sock:/var/run/docker.sock
    environment:
      # Désactive le wizard de configuration initial (optionnel)
      - JAVA_OPTS=-Djenkins.install.runSetupWizard=true

volumes:
  jenkins_home:
    driver: local
