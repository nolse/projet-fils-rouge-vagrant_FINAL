# =============================================================
# SECRETS — icgroup
# =============================================================
# Un Secret stocke les données sensibles (mots de passe, clés)
# encodées en base64. Kubernetes les injecte dans les pods
# sous forme de variables d'environnement.
#
# IMPORTANT : base64 n'est PAS du chiffrement, c'est de
# l'encodage. Ne jamais committer ce fichier avec de vrais
# mots de passe sur un repo public !
#
# Pour encoder en base64 :
#   echo -n "monmotdepasse" | base64
# Pour décoder :
#   echo "bW9ubW90ZGVwYXNzZQ==" | base64 -d
# =============================================================

apiVersion: v1
kind: Secret
metadata:
  name: icgroup-secrets
  namespace: icgroup
type: Opaque
data:
  POSTGRES_DB: <base64 de la valeur>        # echo -n "odoo" | base64
  POSTGRES_USER: <base64 de la valeur>      # echo -n "odoo" | base64
  POSTGRES_PASSWORD: <base64 de la valeur>  # echo -n "odoo_password" | base64
  PGADMIN_EMAIL: <base64 de la valeur>      # echo -n "admin@icgroup.fr" | base64
  PGADMIN_PASSWORD: <base64 de la valeur>   # echo -n "pgadmin_password" | base64
